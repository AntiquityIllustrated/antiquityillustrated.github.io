   .card-title a:hover {\n            color: #e6b422;\n        }\n        .card-desc {\n            color: #b0b0b0;\n            font-size: 0.9rem;\n            margin-bottom: 1rem;\n            display: -webkit-box;\n            -webkit-line-clamp: 3;\n            -webkit-box-orient: vertical;\n            overflow: hidden;\n            line-height: 1.5;\n        }\n        .card-date {\n            font-size: 0.8rem;\n            color: #888;\n            background: #1e1e1e;\n            display: inline-block;\n            padding: 0.2rem 0.7rem;\n            border-radius: 20px;\n            margin-bottom: 1rem;\n            align-self: flex-start;\n        }\n        .watch-link {\n            display: inline-flex;\n            align-items: center;\n            gap: 8px;\n            background-color: #ff0000;\n            color: white;\n            padding: 0.5rem 1rem;\n            border-radius: 40px;\n            text-decoration: none;\n            font-weight: 600;\n            font-size: 0.85rem;\n            transition: background 0.2s;\n            margin-top: auto;\n            align-self: flex-start;\n        }\n        .watch-link:hover {\n            background-color: #cc0000;\n        }\n        footer {\n            text-align: center;\n            margin-top: 3rem;\n            padding-top: 2rem;\n            border-top: 1px solid #2a2a2a;\n            color: #777;\n            font-size: 0.85rem;\n        }\n        footer a {\n            color: #e6b422;\n            text-decoration: none;\n        }\n        @media (max-width: 700px) {\n            .home-container {\n                padding: 1rem;\n            }\n            .hero h1 {\n                font-size: 2rem;\n            }\n            .hero p {\n                font-size: 1rem;\n            }\n        }\n    <\/style>\n<\/head>\n<body>\n<div class=\"home-container\">\n    <div class=\"hero\">\n        <h1>\ud83c\udfdb\ufe0f Antiquity Illustrated<\/h1>\n        <p style=\"text-wrap: balance;\">Cinematic animated retellings of Mthology. Gods, heroes, monsters \u2013 brought to life.<\/p>\n<\/div>\n\n    <div class=\"subscribe-center\">\n        <a href=\"https:\/\/www.youtube.com\/@antiquityillustrated?sub_confirmation=1\" target=\"_blank\" class=\"subscribe-btn\">\n            \ud83d\udcfa Subscribe on YouTube\n        <\/a>\n    <\/div>\n\n    <div class=\"myth-grid\">\n        <!-- Icarus: immagine e titolo linkano alla pagina interna, pulsante link YouTube -->\n        <div class=\"card\">\n            <a href=\"\/icarus-myth-explained\">\n                <img decoding=\"async\" src=\"https:\/\/img.youtube.com\/vi\/rD7-OJtkH-Q\/maxresdefault.jpg\" alt=\"Icarus and Daedalus\">\n            <\/a>\n            <div class=\"card-content\">\n                <div class=\"card-title\">\n                    <a href=\"\/icarus-myth-explained\">Icarus &#038; Daedalus: The Flight Too Close to the Sun<\/a>\n                <\/div>\n                <div class=\"card-desc\">The most famous cautionary tale of Greek myth. Daedalus builds wax wings to escape Crete, but his son Icarus flies too high \u2013 the sun melts the wax, and he falls into the sea.<\/div>\n                <div class=\"card-date\">\ud83d\udcc5 April 22, 2026<\/div>\n                <a href=\"https:\/\/youtu.be\/rD7-OJtkH-Q\" target=\"_blank\" class=\"watch-link\">\u25b6 Watch on YouTube<\/a>\n            <\/div>\n        <\/div>\n\n        <!-- Theseus -->\n        <div class=\"card\">\n            <a href=\"\/theseus-myth-explained\">\n                <img decoding=\"async\" src=\"https:\/\/img.youtube.com\/vi\/uWrjals0gSI\/maxresdefault.jpg\" alt=\"Theseus and the Minotaur\">\n            <\/a>\n            <div class=\"card-content\">\n                <div class=\"card-title\">\n                    <a href=\"\/theseus-myth-explained\">Theseus: Why He Was Not the Hero You Think<\/a>\n                <\/div>\n                <div class=\"card-desc\">The slayer of the Minotaur, founder of Athens\u2026 but also an abductor, a negligent king, and a man who caused his own son\u2019s death. A critical look at the \u201chero\u201d of the Labyrinth.<\/div>\n                <div class=\"card-date\">\ud83d\udcc5 April 19, 2026<\/div>\n                <a href=\"https:\/\/youtu.be\/uWrjals0gSI\" target=\"_blank\" class=\"watch-link\">\u25b6 Watch on YouTube<\/a>\n            <\/div>\n        <\/div>\n\n        <!-- Pandora -->\n        <div class=\"card\">\n            <a href=\"\/pandora-myth-explained\">\n                <img decoding=\"async\" src=\"https:\/\/img.youtube.com\/vi\/k4UvCJiUxyo\/maxresdefault.jpg\" alt=\"Pandora's Box\">\n            <\/a>\n            <div class=\"card-content\">\n                <div class=\"card-title\">\n                    <a href=\"\/pandora-myth-explained\">Pandora&#8217;s Box: Curiosity and the First Curse<\/a>\n                <\/div>\n                <div class=\"card-desc\">The first woman created by the gods, a jar (not a box) containing all evils, and one tiny hope. Why Pandora\u2019s story is a warning about curiosity.<\/div>\n                <div class=\"card-date\">\ud83d\udcc5 April 15, 2026<\/div>\n                <a href=\"https:\/\/youtu.be\/k4UvCJiUxyo\" target=\"_blank\" class=\"watch-link\">\u25b6 Watch on YouTube<\/a>\n            <\/div>\n        <\/div>\n\n        <!-- Poseidon -->\n        <div class=\"card\">\n            <a href=\"\/poseidon-myth-explained\">\n                <img decoding=\"async\" src=\"https:\/\/img.youtube.com\/vi\/dB1MHLiD-x8\/maxresdefault.jpg\" alt=\"Poseidon\">\n            <\/a>\n            <div class=\"card-content\">\n                <div class=\"card-title\">\n                    <a href=\"\/poseidon-myth-explained\">Poseidon: The God of Storms, Seas, and Revenge<\/a>\n                <\/div>\n                <div class=\"card-desc\">Why was the Earthshaker so feared? From the Trojan War to the wrath against Odysseus, discover the violent nature of the Olympian god of the sea.<\/div>\n                <div class=\"card-date\">\ud83d\udcc5 April 8, 2026<\/div>\n                <a href=\"https:\/\/youtu.be\/dB1MHLiD-x8\" target=\"_blank\" class=\"watch-link\">\u25b6 Watch on YouTube<\/a>\n            <\/div>\n        <\/div>\n\n        <!-- Prometheus -->\n        <div class=\"card\">\n            <a href=\"\/prometheus-myth-explained\">\n                <img decoding=\"async\" src=\"https:\/\/img.youtube.com\/vi\/moH4f7ZOYbY\/maxresdefault.jpg\" alt=\"Prometheus\">\n            <\/a>\n            <div class=\"card-content\">\n                <div class=\"card-title\">\n                    <a href=\"\/prometheus-myth-explained\">Prometheus: The Titan Who Stole Fire<\/a>\n                <\/div>\n                <div class=\"card-desc\">The defiant Titan who stole fire from the gods and gave it to humanity. Zeus punished him with eternal torment \u2013 an eagle eating his liver each day.<\/div>\n                <div class=\"card-date\">\ud83d\udcc5 April 4, 2026<\/div>\n                <a href=\"https:\/\/youtu.be\/moH4f7ZOYbY\" target=\"_blank\" class=\"watch-link\">\u25b6 Watch on YouTube<\/a>\n            <\/div>\n        <\/div>\n\n        <!-- Medusa -->\n        <div class=\"card\">\n            <a href=\"\/medusa-myth-explained\">\n                <img decoding=\"async\" src=\"https:\/\/img.youtube.com\/vi\/6E_8q_szAW4\/maxresdefault.jpg\" alt=\"Medusa\">\n            <\/a>\n            <div class=\"card-content\">\n                <div class=\"card-title\">\n                    <a href=\"\/medusa-myth-explained\">Medusa: Monster or Victim? The Truth Behind the Myth<\/a>\n                <\/div>\n                <div class=\"card-desc\">Was Medusa a terrifying Gorgon or a cursed priestess of Athena? Discover her tragic transformation, the gaze of stone, and the hero Perseus who beheaded her.<\/div>\n                <div class=\"card-date\">\ud83d\udcc5 April 1, 2026<\/div>\n                <a href=\"https:\/\/youtu.be\/6E_8q_szAW4\" target=\"_blank\" class=\"watch-link\">\u25b6 Watch on YouTube<\/a>\n            <\/div>\n        <\/div>\n    <\/div>\n\n    <footer>\n    <p>\u00a9 2026 Antiquity Illustrated \u2013 <a href=\"https:\/\/www.youtube.com\/@antiquityillustrated\" target=\"_blank\">Subscribe on YouTube<\/a><\/p>\n    <p style=\"margin-top: 0.5rem; font-size: 0.75rem;\">\n        <a href=\"\/privacy-policy\" style=\"color: #888; text-decoration: none;\">Privacy Policy<\/a> &nbsp;|&nbsp;\n        <a href=\"\/cookie-policy\" style=\"color: #888; text-decoration: none;\">Cookie Policy<\/a>\n    <\/p>\n<\/footer>\n<\/div>\n<\/body>\n<\/html>\n\n\n\n<p><\/p>\n","protected":false},"excerpt":{"rendered":"<p>Greek Mythology Animated | Antiquity Illustrated \ud83c\udfdb\ufe0f Antiquity Illustrated Cinematic animated retellings of Mthology. Gods, heroes, monsters \u2013 brought to [&hellip;]<\/p>\n","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"full-width-container","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"disabled","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"disabled","ast-disable-related-posts":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","backgro